// Shared material library — import this file to use these materials
let matte_white = material { color (1.0, 1.0, 1.0)  opacity 1.0  reflect 0.0  ior 1.0 }
let matte_gray  = material { color (0.5, 0.5, 0.5)  opacity 1.0  reflect 0.0  ior 1.0 }
let glass       = material { color (0.8, 0.9, 1.0)  opacity 0.0  reflect 0.0  ior 1.5 }
let mirror      = material { color (0.95, 0.95, 0.95)  opacity 1.0  reflect 0.9  ior 1.0 }
